# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# This project supports two setups:
# 1. Local stack
#    - App: `npm run dev`
#    - Supabase: `supabase start`
#    - Docling worker: `docker compose -f docker-compose.docling-worker.yml up --build`
#    - Browser runner: optional, `npm run bridge:runner`
# 2. Cloud stack
#    - App: Vercel
#    - Supabase: supabase.com
#    - Docling worker: Railway
#    - Browser runner: optional, can still run locally
#
# Canonical env names used by the app:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_PUBLIC_KEY
# - SUPABASE_SECRET_KEY
# - DOCUMENT_IMPORT_SERVICE_URL
# - DOCUMENT_IMPORT_CALLBACK_SECRET
# - DOC_IMPORT_SUPABASE_URL
# - BRIDGE_RUNNER_SECRET (only if you use the runner)
# - BRIDGE_RUNNER_APP_URL (optional, only when the runner should target a hosted app instead of localhost)

# ------------------------------
# Local stack example
# ------------------------------
# Use the values printed by `supabase start`:
# - Project URL: http://127.0.0.1:54321
# - Public key: shown as "Publishable"
# - Secret key: shown as "Secret"

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=sb_publishable_replace_with_local_publishable_key
SUPABASE_SECRET_KEY=sb_secret_replace_with_local_secret_key

# Next.js app -> local Docling worker
DOCUMENT_IMPORT_SERVICE_URL=http://localhost:8090

# Must match between the app and the worker.
DOCUMENT_IMPORT_CALLBACK_SECRET=replace-with-one-shared-random-secret

# Worker-only override for Docker.
# Leave this as-is for local Docker unless your setup differs.
DOC_IMPORT_SUPABASE_URL=http://host.docker.internal:54321

# Optional: only needed if you use `npm run bridge:runner`
BRIDGE_RUNNER_SECRET=replace-with-one-shared-random-secret
# Optional: use this only when the local runner should talk to a hosted app.
# BRIDGE_RUNNER_APP_URL=https://your-app.vercel.app

# ------------------------------
# Cloud stack values
# ------------------------------
# Put these same env names into the provider dashboards:
#
# Vercel:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=sb_publishable_replace_with_cloud_publishable_key
# SUPABASE_SECRET_KEY=sb_secret_replace_with_cloud_secret_key
# DOCUMENT_IMPORT_SERVICE_URL=https://your-docling-worker.up.railway.app
# DOCUMENT_IMPORT_CALLBACK_SECRET=replace-with-one-shared-random-secret
#
# Railway:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_replace_with_cloud_secret_key
# DOCUMENT_IMPORT_CALLBACK_SECRET=replace-with-one-shared-random-secret
# DOC_IMPORT_SUPABASE_URL=
#
# Supabase dashboard mapping:
# Project URL -> NEXT_PUBLIC_SUPABASE_URL
# Publishable key -> NEXT_PUBLIC_SUPABASE_PUBLIC_KEY
# Secret key -> SUPABASE_SECRET_KEY

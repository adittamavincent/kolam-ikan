# Stage: local app + local Supabase + local Docling worker
# Use the values printed by `supabase start`
# - Project URL: http://127.0.0.1:54321
# - Public key: shown as "Publishable"
# - Secret key: shown as "Secret"

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=PASTE_LOCAL_PUBLIC_KEY_HERE
SUPABASE_SECRET_KEY=PASTE_LOCAL_SECRET_KEY_HERE

# Docker containers cannot reach your host via 127.0.0.1, so the worker uses Docker's host alias.
DOC_IMPORT_SUPABASE_URL=http://host.docker.internal:54321

DOCUMENT_IMPORT_SERVICE_URL=http://localhost:8090
DOCUMENT_IMPORT_CALLBACK_SECRET=replace-with-one-shared-secret
DOCUMENT_IMPORT_APP_URL=http://localhost:3000
BRIDGE_RUNNER_SECRET=change-me
BRIDGE_RUNNER_APP_URL=http://localhost:3000
BRIDGE_RUNNER_HEALTH_PORT=3001
# BRIDGE_RUNNER_HEALTH_URL=http://127.0.0.1:3001/health
# NEXT_PUBLIC_BRIDGE_RUNNER_HEALTH_PORT=3001
# NEXT_PUBLIC_BRIDGE_RUNNER_HEALTH_URL=http://127.0.0.1:3001/health
BRIDGE_RUNNER_PROVIDERS=chatgpt,gemini,claude
BRIDGE_RUNNER_PROFILE_DIR=.auth/bridge-runner-profile
BRIDGE_RUNNER_POLL_INTERVAL_MS=3000
BRIDGE_RUNNER_BROWSER_WIDTH=1280
BRIDGE_RUNNER_BROWSER_HEIGHT=820
# Optional defaults per provider when you want to pin a model during runner tests.
# BRIDGE_RUNNER_MODEL_CHATGPT=gpt-5
# BRIDGE_RUNNER_MODEL_GEMINI=2.5-pro
# BRIDGE_RUNNER_MODEL_CLAUDE=sonnet

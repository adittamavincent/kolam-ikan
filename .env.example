# Canonical env names for this project.
# Copy one of the stage templates below into `.env.local` when developing:
# - `.env.local.example`
# - `.env.local-cloud.example`
# - `.env.preview.example`
# - `.env.production.example`

# Public app config: safe for browser use
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Server-only secret: required by Next.js server routes, e2e reset helpers, and Docling worker
SUPABASE_SECRET_KEY=YOUR_SECRET_KEY

# Optional worker-only override.
# Use this only when the Docling worker must reach Supabase through a different hostname
# than the browser/app uses, such as Docker's `host.docker.internal`.
DOC_IMPORT_SUPABASE_URL=

# Docling worker integration
DOCUMENT_IMPORT_SERVICE_URL=https://your-docling-worker.up.railway.app
DOCUMENT_IMPORT_CALLBACK_SECRET=the-same-random-secret
DOCUMENT_IMPORT_APP_URL=https://your-app.vercel.app
BRIDGE_RUNNER_SECRET=change-me
BRIDGE_RUNNER_APP_URL=http://localhost:3000
BRIDGE_RUNNER_HEALTH_PORT=3001
# BRIDGE_RUNNER_HEALTH_URL=http://127.0.0.1:3001/health
# NEXT_PUBLIC_BRIDGE_RUNNER_HEALTH_PORT=3001
# NEXT_PUBLIC_BRIDGE_RUNNER_HEALTH_URL=http://127.0.0.1:3001/health
BRIDGE_RUNNER_PROVIDERS=chatgpt,gemini,claude
BRIDGE_RUNNER_PROFILE_DIR=.auth/bridge-runner-profile
BRIDGE_RUNNER_POLL_INTERVAL_MS=3000
BRIDGE_RUNNER_BROWSER_WIDTH=1280
BRIDGE_RUNNER_BROWSER_HEIGHT=820
# BRIDGE_RUNNER_MODEL_CHATGPT=gpt-5
# BRIDGE_RUNNER_MODEL_GEMINI=2.5-pro
# BRIDGE_RUNNER_MODEL_CLAUDE=sonnet
